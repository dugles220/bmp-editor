{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Make (gdb debug)", 
            "type": "cppdbg",
            "request": "launch",
            "program": "/bin/bash",
            "args": [
                "-c",
                "${workspaceFolder}/cw ${input:getArgs}"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "Make Build",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ],
    "inputs": [
        {
            "id": "getArgs",
            "type": "promptString",
            "description": "write flags",
            "default": ""
        }
    ]
}