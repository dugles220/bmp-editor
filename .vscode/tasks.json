{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Make Build", // название команды - сборка программы
            "type": "shell",
            "command": "make", // вводимая в терминал команда
            "args": [
                "cw" // флаги команды 
            ],
            "group": {
                "kind": "build",
                "isDefault": true // запускается на Ctrl+Shift+B
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Make Clean", // название команды - очистка файлов компиляции
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "problemMatcher": []
        }
    ]
}